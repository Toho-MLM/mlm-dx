{
  "name": "mlm-dx",
  "version": "1.0.0",
  "private": true,
  "description": "MLM-DX monorepo with Next.js frontend and Cloudflare Workers backend",
  "workspaces": [
    "apps/web",
    "apps/worker"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "dev:worker:local": "npm run dev:local --workspace=apps/worker",
    "dev:all": "concurrently \"npm run dev:worker\" \"npm run dev\"",
    "dev:all:local": "concurrently \"npm run dev:worker:local\" \"npm run dev\"",
    "build": "npm run build --workspace=apps/web",
    "build:worker": "npm run build --workspace=apps/worker",
    "build:all": "npm run build:worker && npm run build",
    "deploy:worker": "npm run deploy --workspace=apps/worker",
    "deploy:worker:dev": "npm run deploy:dev --workspace=apps/worker",
    "db:create": "npm run db:create --workspace=apps/worker",
    "db:create:dev": "npm run db:create:dev --workspace=apps/worker",
    "db:migrate": "npm run db:migrate --workspace=apps/worker",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=apps/worker",
    "db:migrate:local": "npm run db:migrate:local --workspace=apps/worker",
    "db:seed": "npm run db:seed --workspace=apps/worker",
    "db:seed:dev": "npm run db:seed:dev --workspace=apps/worker",
    "db:seed:local": "npm run db:seed:local --workspace=apps/worker",
    "db:setup": "npm run db:setup --workspace=apps/worker",
    "db:setup:dev": "npm run db:setup:dev --workspace=apps/worker",
    "db:setup:local": "npm run db:setup:local --workspace=apps/worker",
    "lint": "npm run lint --workspace=apps/web",
    "lint:worker": "npm run lint --workspace=apps/worker",
    "lint:all": "npm run lint && npm run lint:worker",
    "type-check": "npm run type-check --workspace=apps/web && npm run type-check --workspace=apps/worker",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist apps/*/.next apps/worker/.wrangler",
    "install:all": "npm install && npm install --workspace=apps/web && npm install --workspace=apps/worker"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "concurrently": "^8.2.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}