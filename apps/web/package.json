{
  "name": "mlm-dx-web",
  "version": "1.0.0",
  "private": true,
  "description": "MLM-DX Next.js frontend",
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev",
    "build": "next build",
    "build:local": "next build",
    "build:cloud": "next build && npx @cloudflare/next-on-pages",
    "start": "next start",
    "start:local": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "preview": "npx wrangler pages dev .vercel/output/static",
    "preview:local": "next start",
    "deploy": "npm run build:cloud && npx wrangler pages deploy .vercel/output/static",
    "deploy:prod": "npm run build:cloud && npx wrangler pages deploy .vercel/output/static",
    "deploy:dev": "npm run build:cloud && npx wrangler pages deploy .vercel/output/static --env development"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^6.1.8",
    "@mui/material": "^6.1.8",
    "@opennextjs/cloudflare": "^1.11.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@vercel/analytics": "^1.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^11.11.17",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.456.0",
    "next": "^15.5.2",
    "next-auth": "^5.0.0-beta.29",
    "react": "^18",
    "react-big-calendar": "^1.15.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-big-calendar": "^1.16.0",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "wrangler": "^4.43.0"
  }
}
