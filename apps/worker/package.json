{
  "name": "mlm-dx-worker",
  "version": "1.0.0",
  "private": true,
  "description": "MLM-DX Cloudflare Workers backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create mlm-dx-db",
    "db:migrate": "wrangler d1 execute mlm-dx-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute mlm-dx-db --file=./schema.sql --local",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@simplewebauthn/server": "^11.0.0",
    "hono": "^4.0.0",
    "zod": "^4.1.12",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.43.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
