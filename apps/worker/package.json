{
  "name": "mlm-dx-worker",
  "version": "1.0.0",
  "private": true,
  "description": "MLM-DX Cloudflare Workers backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --local",
    "build": "wrangler deploy --dry-run",
    "build:local": "wrangler deploy --dry-run --local",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy",
    "db:create": "wrangler d1 create mlm-dx-db",
    "db:create:local": "echo 'Local D1 database is created automatically when running wrangler dev'",
    "db:create:prod": "wrangler d1 create mlm-dx-db",
    "db:migrate": "wrangler d1 migrations apply mlm-dx-db",
    "db:migrate:local": "wrangler d1 migrations apply mlm-dx-db-local --local",
    "db:migrate:prod": "wrangler d1 migrations apply mlm-dx-db",
    "db:seed": "wrangler d1 execute mlm-dx-db --file=./seed.sql",
    "db:seed:local": "wrangler d1 execute mlm-dx-db-local --file=./seed.sql --local",
    "db:seed:prod": "wrangler d1 execute mlm-dx-db --file=./seed.sql",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:setup:local": "npm run db:migrate:local && npm run db:seed:local",
    "db:setup:prod": "npm run db:migrate:prod && npm run db:seed:prod",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.43.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
